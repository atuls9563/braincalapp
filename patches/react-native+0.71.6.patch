diff --git a/Libraries/Components/DatePicker/DatePickerIOS.js b/Libraries/Components/DatePicker/DatePickerIOS.js
new file mode 100644
index 0000000..a1b2c3d 100644
--- /dev/null
+++ b/Libraries/Components/DatePicker/DatePickerIOS.js
@@ -0,0 +1,14 @@
+/**
+ * @format
+ * Shim so Metro can resolve DatePickerIOS (platform-specific files exist as .ios.js / .android.js)
+ */
+'use strict';
+
+const {Platform} = require('../../Utilities/Platform');
+module.exports =
+  Platform.OS === 'ios'
+    ? require('./DatePickerIOS.ios')
+    : require('./DatePickerIOS.android');
+

