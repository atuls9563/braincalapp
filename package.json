{
  "name": "Braincal",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "postinstall": "patch-package",
    "clean-android": "cd ./android && ./gradlew clean && cd ..",
    "build-bundle": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "build-android": "cd ./android && ./gradlew app:assembleDebug && ./gradlew installDebug && cd ../",
    "npx": "npx react-native start",
    "build-android-release": "cd ./android && ./gradlew app:assembleRelease && cd ../",
    "build-android-bundle": "cd ./android &&  ./gradlew assembleRelease && cd ../"
  },
